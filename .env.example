# Credenciais Shopee
SHOPEE_EMAIL=seu_email@exemplo.com
SHOPEE_PWD=sua_senha

# Connection string do Neon (PostgreSQL)
# Formato: postgresql://user:password@host:port/database
# Exemplo: postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/shopee_etl?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host:port/database

# Configurações do Crawler
CRAWLER_HEADLESS=true
